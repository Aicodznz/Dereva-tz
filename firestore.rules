rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {uid}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string
    //   - photoURL: string
    //   - role: string (required, ['customer', 'vendor', 'rider', 'admin'])
    //   - phoneNumber: string
    //   - address: string
    //   - createdAt: timestamp
    //
    // Collection: vendors
    // Document ID: {vendorId}
    // Fields:
    //   - ownerUid: string (required)
    //   - businessName: string (required)
    //   - category: string (required)
    //   - status: string (required, ['pending', 'active', 'suspended'])
    //   - ... other metadata
    //
    // Collection: products
    // Document ID: {productId}
    // Fields:
    //   - vendorId: string (required)
    //   - name: string (required)
    //   - price: number (required)
    //   - ...
    //
    // Collection: orders
    // Document ID: {orderId}
    // Fields:
    //   - customerId: string (required)
    //   - vendorId: string (required)
    //   - status: string (required)
    //   - totalAmount: number (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          request.auth.token.email == "aicodtznation@gmail.com" ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
        );
    }

    function isVendorOwner(vendorId) {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/vendors/$(vendorId)) && 
             get(/databases/$(database)/documents/vendors/$(vendorId)).data.ownerUid == request.auth.uid;
    }

    function isRider() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'rider';
    }

    function isValidMessage(data) {
      return data.text is string && data.text.size() > 0 && data.text.size() < 1000 &&
             data.senderId == request.auth.uid &&
             data.participants is list && data.participants.size() >= 2 &&
             request.auth.uid in data.participants;
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && request.auth.uid == userId;
    }

    match /vendors/{vendorId} {
      allow read: if true; // Publicly viewable
      allow create: if isAuthenticated();
      allow update: if (isAuthenticated() && resource.data.ownerUid == request.auth.uid) || isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isAuthenticated(); // Simplified for now
      allow update: if isAuthenticated(); // Simplified for now
      allow delete: if isAuthenticated(); // Simplified for now
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.customerId || 
        request.auth.uid == resource.data.riderId || 
        isAdmin() ||
        resource.data.status == 'ready_for_pickup' ||
        (resource.data.vendorId != null && isVendorOwner(resource.data.vendorId))
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
    }

    match /tables/{tableId} {
      allow read: if true;
      allow create: if isAuthenticated() && (isAdmin() || (request.resource.data.vendorId != null && isVendorOwner(request.resource.data.vendorId)));
      allow update: if isAuthenticated() && (isAdmin() || (resource.data.vendorId != null && isVendorOwner(resource.data.vendorId)));
      allow delete: if isAuthenticated() && (isAdmin() || (resource.data.vendorId != null && isVendorOwner(resource.data.vendorId)));
    }

    match /riders/{riderId} {
      allow read: if isAuthenticated();
      allow create: if isRider() && request.auth.uid == riderId;
      allow update: if (isRider() && request.auth.uid == riderId) || isAdmin();
    }

    match /messages/{messageId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && isValidMessage(request.resource.data);
      allow update: if false; // Messages are immutable for now
      allow delete: if false;
    }

    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAdmin();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /coupons/{couponId} {
      allow read: if true;
      allow create: if isAuthenticated() && (isAdmin() || (request.resource.data.vendorId != null && isVendorOwner(request.resource.data.vendorId)));
      allow update: if isAuthenticated() && (isAdmin() || (resource.data.vendorId != null && isVendorOwner(resource.data.vendorId)));
      allow delete: if isAuthenticated() && (isAdmin() || (resource.data.vendorId != null && isVendorOwner(resource.data.vendorId)));
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes']))
      );
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());

      match /replies/{replyId} {
        allow read: if true;
        allow create: if isAuthenticated();
        allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
        allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      }
    }
  }
}
