{
  "entities": {
    "User": {
      "title": "User",
      "description": "Core user profile for all roles",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "vendor", "rider", "admin"] },
        "phoneNumber": { "type": "string" },
        "address": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Vendor": {
      "title": "Vendor",
      "description": "Business profile for service providers",
      "type": "object",
      "properties": {
        "ownerUid": { "type": "string" },
        "businessName": { "type": "string" },
        "category": { "type": "string", "enum": ["pharmacy", "grocery", "restaurant", "parcel", "taxi", "car_rental", "salon", "hotel", "ecommerce"] },
        "description": { "type": "string" },
        "tin": { "type": "string" },
        "address": { "type": "string" },
        "location": { "type": "object" },
        "deliveryRadius": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "active", "suspended"] },
        "logoUrl": { "type": "string" },
        "operatingHours": { "type": "string" },
        "rating": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerUid", "businessName", "category", "status"]
    },
    "Product": {
      "title": "Product",
      "description": "Items or services offered by vendors",
      "type": "object",
      "properties": {
        "vendorId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "stock": { "type": "number" },
        "imageUrl": { "type": "string" },
        "unit": { "type": "string" },
        "expiryDate": { "type": "string", "format": "date" },
        "medicationType": { "type": "string", "enum": ["otc", "prescription"] },
        "variations": { "type": "array" }
      },
      "required": ["vendorId", "name", "price"]
    },
    "Order": {
      "title": "Order",
      "description": "Transactions between customers and vendors",
      "type": "object",
      "properties": {
        "customerId": { "type": "string" },
        "vendorId": { "type": "string" },
        "riderId": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "accepted", "preparing", "out_for_delivery", "delivered", "cancelled"] },
        "type": { "type": "string" },
        "prescriptionUrl": { "type": "string" },
        "deliveryAddress": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerId", "vendorId", "status", "totalAmount"]
    },
    "Rider": {
      "title": "Rider",
      "description": "Logistics and transport provider profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "vehicleDetails": { "type": "string" },
        "status": { "type": "string", "enum": ["available", "busy", "offline"] },
        "currentPosition": { "type": "object" },
        "rating": { "type": "number" }
      },
      "required": ["uid", "status"]
    },
    "Message": {
      "title": "Message",
      "description": "Chat messages between users",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "participants": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["text", "senderId", "participants"]
    },
    "Banner": {
      "title": "Banner",
      "description": "Promotional banners for the home screen",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "sub": { "type": "string" },
        "img": { "type": "string" },
        "link": { "type": "string" },
        "active": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "img", "active"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System or user-specific notifications",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "body": { "type": "string" },
        "type": { "type": "string", "enum": ["order", "promotion", "system", "review"] },
        "userId": { "type": "string" },
        "isRead": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "actionUrl": { "type": "string" }
      },
      "required": ["title", "body", "type", "isRead"]
    },
    "Review": {
      "title": "Review",
      "description": "User reviews for vendors and products",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "targetId": { "type": "string", "description": "Vendor ID or Product ID" },
        "targetType": { "type": "string", "enum": ["vendor", "product"] },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "images": { "type": "array" },
        "likes": { "type": "array", "description": "Array of user UIDs who liked this review" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "targetId", "targetType", "rating"]
    },
    "Reply": {
      "title": "Reply",
      "description": "Vendor or user reply to a review",
      "type": "object",
      "properties": {
        "reviewId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["reviewId", "userId", "text"]
    },
    "Coupon": {
      "title": "Coupon",
      "description": "Discount codes for products or vendors",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "discountType": { "type": "string", "enum": ["percentage", "fixed"] },
        "discountValue": { "type": "number" },
        "validFrom": { "type": "string", "format": "date-time" },
        "validUntil": { "type": "string", "format": "date-time" },
        "usageLimit": { "type": "number" },
        "usedCount": { "type": "number" },
        "vendorId": { "type": "string", "description": "Vendor ID if specific to a vendor, null for global" },
        "productId": { "type": "string", "description": "Product ID if specific to a product, null for all products of vendor/global" },
        "active": { "type": "boolean" },
        "createdBy": { "type": "string", "description": "Admin or Vendor UID" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["code", "discountType", "discountValue", "active"]
    }
  },
  "firestore": {
    "/users/{uid}": { "schema": "User", "description": "User profiles" },
    "/vendors/{vendorId}": { "schema": "Vendor", "description": "Vendor business profiles" },
    "/products/{productId}": { "schema": "Product", "description": "Vendor products/services" },
    "/orders/{orderId}": { "schema": "Order", "description": "Service orders" },
    "/riders/{uid}": { "schema": "Rider", "description": "Rider profiles" },
    "/messages/{messageId}": { "schema": "Message", "description": "Chat messages" },
    "/banners/{bannerId}": { "schema": "Banner", "description": "Promotional banners" },
    "/notifications/{notificationId}": { "schema": "Notification", "description": "User notifications" },
    "/reviews/{reviewId}": { "schema": "Review", "description": "User reviews" },
    "/reviews/{reviewId}/replies/{replyId}": { "schema": "Reply", "description": "Replies to a review" },
    "/coupons/{couponId}": { "schema": "Coupon", "description": "Discount coupons" }
  }
}
